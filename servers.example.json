{
  "servers": {
    "satisfactory": {
      "label": "Satisfactory Server",
      "region": "ap-northeast-1",
      "instanceType": "t3.xlarge",
      "amiPrefix": "satisfactory-",
      "description": "Satisfactory Dedicated Server",
      "allowedGuilds": [],
      "sshUser": "ubuntu",
      "stopCommand": "sudo systemctl stop satisfactory",
      "startCommand": "sudo systemctl start satisfactory",
      "securityGroupPorts": [7777, 8888],
      "rootVolumeSize": 30,
      "postStartHook": "satisfactory",
      "hookConfig": {
        "adminPassword": "admin"
      },
      "downloadableFiles": {
        "save": {
          "path": "/home/steam/.config/Epic/FactoryGame/Saved/SaveGames/server",
          "description": "セーブデータ",
          "type": "directory"
        }
      }
    }
  }
}
